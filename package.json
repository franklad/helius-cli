{
  "name": "helius-cli",
  "version": "0.1.0",
  "description": "CLI for the Helius Solana API",
  "type": "module",
  "bin": {
    "helius": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outfile dist/index.js --target node",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "incur": "^0.1.8"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
